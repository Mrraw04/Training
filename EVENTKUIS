  <script>
    (function(){
      const form = document.getElementById('quizForm');
      const modal = document.getElementById('rulesModal');
      const confirmed = document.getElementById('rules_confirmed');
      const noBtn = document.getElementById('btnRulesNo');
      const yesBtn = document.getElementById('btnRulesYes');
      const closeBtn = document.getElementById('btnRulesClose');

      function openRulesModal(){
        if (!modal) return;
        modal.classList.add('is-open');
        document.body.classList.add('rules-modal-open');
        setTimeout(function(){ if (closeBtn) closeBtn.focus(); }, 0);
      }
      function closeRulesModal(showAlert){
        if (!modal) return;
        modal.classList.remove('is-open');
        document.body.classList.remove('rules-modal-open');
        if (showAlert) alert('Jawaban tidak dikirim. Silakan ikuti rules dan ketentuannya terlebih dahulu.');
      }

      if (form && modal && confirmed) {
        form.addEventListener('submit', function(e){
          if (confirmed.value === '1') return;
          e.preventDefault();
          openRulesModal();
        });
        if (noBtn) noBtn.addEventListener('click', function(){ closeRulesModal(true); });
        if (closeBtn) closeBtn.addEventListener('click', function(){ closeRulesModal(false); });
        modal.addEventListener('click', function(e){ if (e.target === modal) closeRulesModal(false); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.classList.contains('is-open')) closeRulesModal(false); });
        if (yesBtn) yesBtn.addEventListener('click', function(){
          confirmed.value = '1';
          closeRulesModal(false);
          form.submit();
        });
      }

      document.querySelectorAll('input[name="score_a"],input[name="score_b"]').forEach(function(inp){
        inp.addEventListener('input', function(){ this.value = this.value.replace(/[^0-9]/g,'').slice(0,2); });
      });
      const inp = document.getElementById('answer');
      if (inp) {
        const type = (inp.dataset.atype || 'number').toLowerCase();
        function sanitize(v){ v=String(v||''); if(type==='number')return v.replace(/[^0-9]/g,''); if(type==='alpha')return v.replace(/[^A-Za-z ]/g,'').replace(/\s{2,}/g,' ').replace(/^\s+/,'').toUpperCase(); if(type==='alnum')return v.replace(/[^A-Za-z0-9 ]/g,'').replace(/\s{2,}/g,' ').replace(/^\s+/,'').toUpperCase(); return v; }
        inp.addEventListener('input', function(){ const after=sanitize(this.value); if(this.value!==after)this.value=after; });
      }
      const nodes = Array.from(document.querySelectorAll('.js-countdown'));
      function pad(n){return String(n).padStart(2,'0');}
      function formatCountdown(seconds){
        let diff = Math.max(0, Math.floor(seconds));
        const d = Math.floor(diff / 86400); diff %= 86400;
        const h = Math.floor(diff / 3600); diff %= 3600;
        const m = Math.floor(diff / 60);
        const sec = diff % 60;
        return d > 0 ? (d + 'h ' + pad(h) + ':' + pad(m) + ':' + pad(sec)) : (pad(h) + ':' + pad(m) + ':' + pad(sec));
      }
      function tick(){
        const now = Date.now();
        nodes.forEach(function(node){
          const raw = node.getAttribute('data-target') || node.getAttribute('data-close') || '';
          const target = Date.parse(raw);
          if(!Number.isFinite(target)) return;
          const diff = Math.floor((target-now)/1000);
          if(diff<=0){node.textContent=node.getAttribute('data-done') || 'Selesai';return;}
          node.textContent = formatCountdown(diff);
        });
      }
      tick(); setInterval(tick,1000);
    })();
  </script>
